{
  "name": "fuxicun-website",
  "version": "1.0.0",
  "description": "з»Ӯеҝ”йӮҜйҸүжҲқз•јйҸӮеңӯз¶үз»”?- Cloudflare Pages + D1 + R2 + KV",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev . --d1=FUXICUN_DB --kv=FUXICUN_KV --r2=FUXICUN_BUCKET",
    "deploy": "wrangler pages deploy .",
    "db:init": "wrangler d1 execute www-fuxicun-top-d1 --remote --file=sql/create-tables.sql",
    "db:seed": "wrangler d1 execute www-fuxicun-top-d1 --remote --file=sql/default-data.sql",
    "db:init:local": "wrangler d1 execute www-fuxicun-top-d1 --local --file=sql/create-tables.sql",
    "db:seed:local": "wrangler d1 execute www-fuxicun-top-d1 --local --file=sql/default-data.sql"
  },
  "devDependencies": {
    "puppeteer-core": "^25.0.4",
    "wrangler": "^4"
  },
  "dependencies": {
    "@cloudflare/workerd-windows-64": "^1.20260523.1"
  }
}
